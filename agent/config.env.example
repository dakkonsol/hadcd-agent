# =====================================================================
# HADCD node agent — configuration template
# =====================================================================
#
# Copy this file to /etc/hadcd-agent/agent.env (Linux) or
# %ProgramData%\hadcd-agent\agent.env (Windows) and edit. Every field
# below has a sane default; the four marked *** REQUIRED *** are the
# ones you must change for the agent to work at all.
#
# This file is read at agent startup; changes take effect on the next
# restart. Comments and blank lines are ignored. Values are plain
# strings — no quoting needed unless they contain whitespace.

# =====================================================================
# RECOMMENDED COMPANION: Sunshine (read this first)
# =====================================================================
#
# HADCD strongly recommends installing Sunshine on this machine. It
# gives you two things:
#   1. Remote desktop / game streaming — run Moonlight on your laptop,
#      and this machine does the GPU work (gaming, AI apps, editing).
#   2. Session detection — the agent learns when YOU are using the
#      machine and pauses background mining / heat-fill so it never
#      competes with you for the GPU.
#
# Install Sunshine (free, open source) BEFORE configuring the agent:
#   https://github.com/LizardByte/Sunshine/releases
# Then set SESSION_SOURCE=sunshine + SUNSHINE_PASSWORD below.
# Full walkthrough: docs/sunshine-setup.md
#
# The agent runs without it (and logs a loud advisory), but you lose
# the "don't mine while I'm gaming" behaviour.

# =====================================================================
# *** REQUIRED *** — change these four for any deployment
# =====================================================================

# (1) URL of the central HADCD server. Include the scheme. In a typical
#     production deployment this points at the public TLS endpoint of
#     the reverse proxy in front of the backend; in dev / on a VPN it
#     can be a private hostname.
HADCD_API=https://hadcd.example.org

# (2) The enrollment secret(s) for first-time registration. The central
#     server's operator hands you this value — it lives in their .env
#     under ENROLLMENT_TOKENS. Comma-separated to support rotation;
#     the agent uses the first non-empty value.
#
#     After the agent enrolls once, the issued node bearer is written
#     to AGENT_STATE_FILE and used for all subsequent calls. The
#     enrollment token is only needed for that first start (and again
#     if you ever lose the state file).
ENROLLMENT_TOKENS=hadcd_enroll_REPLACE_ME

# (3) A human-readable name for your building / node. Shows up in the
#     operator UI and in logs. Keep it short and unambiguous, e.g.
#     "Smithtown Community Centre", "City Hall Arena".
NODE_NAME=Set Me To The Building Name

# (Optional) Zone name — the physical room or zone this node heats.
# Set when running multiple nodes in the same building so the operator
# UI groups them by room. Leave blank for a single-node deployment or
# a server-closet catch-all.  e.g. "Living Room", "Office", "Bedroom 2"
ZONE_NAME=

# (Optional) Require own demand. When true, this node only receives
# work when its own thermostat is calling for heat — it never acts as
# overflow for another room's demand.
# Set true for room-paired nodes; false (default) for a catch-all.
REQUIRE_OWN_DEMAND=false

# (4) Maximum sustained power draw of the compute hardware participating
#     as this node, in kilowatts. Used by the dispatcher to size the
#     work it sends. Be honest — overstating it just causes the
#     dispatcher to send tasks that you then can't finish in their
#     forecast window, which triggers recalls.
#
#     Reasonable values: an office PC ~ 0.3, a small rack server ~ 1.5,
#     a workstation with a GPU under sustained load ~ 0.8-2.0.
MAX_POWER_KW=1.0

# =====================================================================
# Optional — node profile (the dispatcher uses these to match work)
# =====================================================================

# Free-text classification used for grouping in the operator UI. One of:
#   community_centre | pool | arena | office | other
# Has no effect on dispatch logic — purely a label.
NODE_TYPE=office

# Declared CPU core count. The dispatcher does not currently pin tasks
# to cores; this is informational. Match what's actually available.
CPU_CAPACITY=4

# Declared GPU count. 0 if none. Informational for now (no GPU-typed
# handlers ship yet; a future workload module would consume this).
GPU_CAPACITY=0

# Total GPU VRAM in GiB across all GPUs. Used by the dispatcher to route
# work that declares a VRAM floor. Leave blank for CPU-only nodes.
# Example: 8 for an RTX 4060 8 GB; 24 for an RTX 4090.
GPU_VRAM_GB=

# Inference performance: tokens/sec your hardware generates on the
# network's reference model. IMPORTANT — this drives what you're paid,
# your eligibility for performance-gated work, and the anti-spoof check
# (a GPU_MODEL that doesn't match this is quarantined). Leave blank if
# unbenchmarked; the node is then treated as the weakest candidate and
# is never sent performance-constrained work. Example: 20
PERF_SCORE=

# Declared RAM available to the agent, in GiB. Informational.
RAM_GB=16

# Declared network bandwidth in Mbps. Informational.
BANDWIDTH_MBPS=200

# Media workload (image / video / 3D / audio via ComfyUI). Leave BLANK to
# disable media on this node — the agent then reports media_capable=false
# and the dispatcher never sends it a media session. Set it to a host
# directory (bind-mounted into the ComfyUI container as the model store)
# to opt IN. NOTE: media sessions are only ever dispatched to
# operator-owned nodes (strict-liability content policy) — see
# WORKLOAD_POLICY.md §4a. Example: /var/lib/hadcd-agent/comfyui-models
COMFYUI_MODELS_PATH=

# The ComfyUI container image used for media sessions. Override only to
# pin a specific digest or use a private registry mirror.
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:latest

# =====================================================================
# Optional — runtime behaviour
# =====================================================================

# How many offloaded tasks to run concurrently. Default 1 matches the
# "one building, one accelerator" model and is right for most nodes.
# Raise it if the host has spare cores AND the BMS reports enough
# demand to justify multiple simultaneous burns.
AGENT_CONCURRENCY=1

# Loop cadences, in real seconds. The backend's stale-heartbeat
# threshold is 60s by default, so HEARTBEAT_INTERVAL_SEC much above 20
# is risky.
HEARTBEAT_INTERVAL_SEC=10
DEMAND_INTERVAL_SEC=15
WORK_POLL_INTERVAL_SEC=6

# =====================================================================
# Optional — persistence
# =====================================================================

# Where the agent keeps its node_id + bearer token. Must be writable
# by the agent process and unreadable to other local users (the token
# is bearer auth — leak = full impersonation).
#   Linux:   /var/lib/hadcd-agent/state.json
#   Windows: C:\ProgramData\hadcd-agent\state.json
AGENT_STATE_FILE=/var/lib/hadcd-agent/state.json

# =====================================================================
# BMS heat-demand source
# =====================================================================
#
# How the agent learns "is the building demanding heat right now?".
# Three adapters ship; choose one and set its config below.
#
#   file          — read a JSON file the BMS (or a bridging script)
#                   writes. Best when the BMS lives on the same host.
#   http          — poll a URL that returns the same JSON shape. Best
#                   for a REST-faced BMS or a BACnet/Modbus sidecar.
#   ecobee        — talk to Ecobee's Developer API directly. Requires
#                   a developer API key (ecobee.com/developers) and a
#                   one-time OAuth PIN flow (`python -m agent.ecobee_setup`).
#   homeassistant — poll a local Home Assistant instance. Works with
#                   any thermostat brand HA supports (including Ecobee
#                   via HA, which does NOT need a developer API key).
#                   Recommended for most new deployments.

BMS_SOURCE=file

# How long the BMS expects to keep wanting heat after a reading was
# taken, in seconds. Used as a default when the BMS data does not
# include `expected_window_sec` itself. Affects the dispatcher's
# scoring (longer windows = more work routed your way).
BMS_DEFAULT_WINDOW_SEC=1800

# --- BMS_SOURCE=file -------------------------------------------------

# Path to the JSON file the BMS writes. Required when BMS_SOURCE=file.
# A missing/malformed file is treated as "no demand right now" so the
# dispatcher simply does not offload until the file appears.
#
# Expected JSON (all optional except measured_kw):
#   {
#     "measured_kw":         8.5,    // current heat demand in kW
#     "setpoint_c":          21.0,   // thermostat setpoint
#     "room_temp_c":         19.3,   // current room temp
#     "expected_window_sec": 1800    // optional override of default above
#   }
#
#   Linux:   /var/lib/hadcd-agent/bms.json
#   Windows: C:\ProgramData\hadcd-agent\bms.json
BMS_FILE=/var/lib/hadcd-agent/bms.json

# --- BMS_SOURCE=http -------------------------------------------------

# URL to GET each tick. Required when BMS_SOURCE=http. The response
# body must be the same JSON shape documented above.
BMS_HTTP_URL=

# Optional Authorization header to send verbatim. Common values:
#   "Bearer <opaque-token>"
#   "Basic <base64-of-user:pass>"
# Many BMS REST endpoints sit behind one of these.
BMS_HTTP_AUTH_HEADER=

# Per-request timeout, in seconds. Short on purpose — a slow BMS
# missing one tick is recoverable; a stuck request blocking the
# demand loop is not.
BMS_HTTP_TIMEOUT_SEC=5

# --- BMS_SOURCE=ecobee -----------------------------------------------
#
# Talks to Ecobee's Developer API directly. Run setup once:
#
#   python -m agent.ecobee_setup
#
# That walks you through Ecobee's PIN-based OAuth flow, lists the
# thermostats on your account, and writes a state file containing the
# refresh token + chosen thermostat id. After setup, the agent
# refreshes tokens automatically (Ecobee rotates them on each use;
# the adapter persists the new token atomically).
#
# Prerequisite: a developer app registered at
# https://www.ecobee.com/developers/ with scope `smartRead`. That
# gives you the API key (a.k.a. client ID).

# Developer-app client ID from ecobee.com/developers. Required when
# BMS_SOURCE=ecobee.
ECOBEE_API_KEY=

# Where the agent persists the refresh token + thermostat id between
# restarts. The setup script writes it here; the adapter rotates the
# refresh token in place on each refresh. File is created with 0600.
#   Linux:   /var/lib/hadcd-agent/ecobee_state.json
#   Windows: C:\ProgramData\hadcd-agent\ecobee_state.json
ECOBEE_STATE_FILE=/var/lib/hadcd-agent/ecobee_state.json

# Which thermostat to read (the setup script lists IDs and writes
# the chosen one here for you). Required when BMS_SOURCE=ecobee.
ECOBEE_THERMOSTAT_ID=

# How much heat-demand to report when the thermostat is actively
# calling for heat. Ecobee tells us "heat is on / off"; HADCD works
# in kW. Set this close to your node's expected heat contribution
# when the heating system is running — for a single space-heater
# node, around your MAX_POWER_KW.
ECOBEE_DEMAND_WHEN_HEATING_KW=5.0

# Per-request timeout for Ecobee API calls. Slightly more generous
# than the http adapter because Ecobee's API is occasionally slow.
ECOBEE_TIMEOUT_SEC=10

# =====================================================================
# Interactive-session detection (Phase 10g)
# =====================================================================
#
# Lets the agent detect when YOU are using this machine interactively
# so the dispatcher pauses fill-tier work (mining, synthetic heat-fill)
# and doesn't fight you for the GPU. Reported to the backend on each
# heartbeat.
#
#   none     — no detector. Fill tiers run whenever heat is demanded.
#              The agent logs a loud advisory at startup recommending
#              Sunshine. This is the default.
#   sunshine — poll a local Sunshine instance. A connected Moonlight
#              client (you streaming in) counts as an active session.

SESSION_SOURCE=none

# --- SESSION_SOURCE=sunshine -----------------------------------------

# Sunshine's local web API base URL. The default is Sunshine's
# standard HTTPS port on loopback. Sunshine serves a self-signed
# certificate; the agent does not verify TLS for this localhost call.
SUNSHINE_URL=https://localhost:47990

# Sunshine's admin credentials double as its API credentials (HTTP
# Basic). Username defaults to Sunshine's default. The password is
# the one you set when you first opened https://localhost:47990 —
# required when SESSION_SOURCE=sunshine.
SUNSHINE_USERNAME=sunshine
SUNSHINE_PASSWORD=

# Per-request timeout for the Sunshine API poll, in seconds.
SUNSHINE_TIMEOUT_SEC=5

# =====================================================================
# Home Assistant BMS adapter (Phase 8d)
# =====================================================================
#
# Reads heat demand from a local Home Assistant instance.
# Recommended if you have any smart thermostat — HA supports every
# major brand (Ecobee, Nest, Honeywell, Sinopé, Mysa, Z-Wave, Zigbee,
# etc.) and requires no developer registration.
#
# Prerequisites:
#   1. Home Assistant running on your network (or same machine in Docker).
#      https://www.home-assistant.io/installation/
#   2. Your thermostat added as a climate entity in HA.
#   3. A long-lived access token generated from:
#        Settings → Your profile → Long-lived access tokens → Create token
#      Copy the token immediately — HA only shows it once.
#   4. Your thermostat's entity ID. Find it in HA:
#        Settings → Devices & Services → Entities (filter by "climate")
#      It looks like "climate.living_room" or "climate.ecobee_home".
#
# Then set BMS_SOURCE=homeassistant and the four settings below.

# Base URL of your Home Assistant instance. The default works when HA
# is on the same LAN and has mDNS. Use an IP address if mDNS is
# unreliable (e.g. http://192.168.1.50:8123).
HA_URL=http://homeassistant.local:8123

# *** Long-lived access token — treat this like a password ***
# Generated from HA: Settings → Your profile → Long-lived access tokens
HA_TOKEN=

# The climate entity to read. Required when BMS_SOURCE=homeassistant.
# Example: climate.living_room or climate.ecobee_home
HA_ENTITY_ID=

# kW to report when the thermostat is actively heating. Set this close
# to your node's MAX_POWER_KW — same guidance as ECOBEE_DEMAND_WHEN_HEATING_KW.
HA_DEMAND_WHEN_HEATING_KW=5.0

# Per-request timeout in seconds. HA is local so 5s is generous.
HA_TIMEOUT_SEC=5

# Temperature unit HA is configured in. "C" for Celsius (default,
# correct for Canada and most HA installs); "F" if your HA uses
# Fahrenheit — the adapter converts to Celsius automatically.
HA_TEMPERATURE_UNIT=C

# Optional (Phase 18k): entity ID of an HA switch / input_boolean that
# controls a physical space heater. When set, the autonomous offline
# fallback turns this heater on instead of burning the CPU/GPU — the
# room stays warm without hardware wear. Requires HA_TOKEN to be set.
#   Example: switch.office_space_heater
HA_HEATER_ENTITY_ID=

# Thermostat setpoint (°C) to hold while the building manager has marked
# this node's room vacant (Phase 22 building-hub override). Used when the
# dispatcher does not supply a per-node setback temperature. 13 °C keeps
# pipes safe and recovers quickly when the room is re-opened.
SETBACK_TEMP_C=13.0

# =====================================================================
# Docker image cache (Phase 10d)
# =====================================================================
#
# Pre-pull configured images at startup so they're warm before the
# first matching task arrives. AI images (Whisper, Stable Diffusion,
# Ollama) are 3-20 GB; a cold pull on a home connection can take
# 10-30 minutes and makes the first task appear to hang. Pre-pulling
# amortises that cost while the node is otherwise idle.
#
# After each container task completes, the agent also checks total
# image-layer disk usage and prunes if it exceeds DOCKER_IMAGE_BUDGET_GB.
# Dangling images (untagged intermediate layers) are removed first —
# always safe. Tagged-but-unused images are removed only if the total
# is still over budget after dangling cleanup.

# Comma-separated Docker image references to pull at startup. Images
# already cached on the host are skipped (no redundant network I/O).
# Failed pulls log a warning but don't block startup — the task will
# cold-pull when it eventually runs.
#   Example: ollama/ollama:latest,ghcr.io/openai/whisper:latest
DOCKER_PREPULL_IMAGES=

# Maximum total disk space, in GiB, that Docker image layers may
# occupy before automatic GC kicks in. Set to 0 to disable GC entirely
# (not recommended on nodes with limited storage).
DOCKER_IMAGE_BUDGET_GB=50

# =====================================================================
# GPU mining fill — NiceHash / excavator (Phase 9b)
# =====================================================================
#
# When the backend's fill injector detects idle heat demand, it queues
# "gpu_mining_fill" tasks. This section configures T-Rex Miner, the
# Linux-native NVIDIA miner that connects to NiceHash's stratum pool.
# Payouts land as BTC in your NiceHash wallet — same dashboard, same
# earnings, no Windows required.  Leave NICEHASH_TREX_PATH empty
# (the default) to disable GPU mining on this node — the handler skips
# gracefully and the task simply completes as "skipped".
#
# *** SECURITY NOTE ***
# Wallet addresses are NEVER put in task payloads — they live here, in
# the agent environment, only. The task ledger only ever sees the first
# 8 characters of the wallet address (in the CSV session log).
#
# Downloads:
#   T-Rex Miner (Linux): https://github.com/trexminer/T-Rex/releases
#   The ISO builder bundles it automatically when built with --with-mining.
#   Manual install: extract the tarball and set NICEHASH_TREX_PATH below.

# Full path to the t-rex executable. Leave empty to disable GPU mining.
#   Linux:  /opt/hadcd-source/opt/trex/t-rex
NICEHASH_TREX_PATH=

# *** Your NiceHash Bitcoin payout address. Treat as a password. ***
# Find or create it in the NiceHash dashboard under Wallet > BTC.
NICEHASH_WALLET=

# Worker label shown in the NiceHash dashboard. Defaults to the
# machine's hostname at runtime if left empty.
NICEHASH_WORKER_NAME=

# NiceHash stratum endpoint. The default (auto.nicehash.com:9200)
# lets NiceHash auto-select the most profitable algorithm. Only change
# this if you want to pin a specific algorithm's port.
NICEHASH_POOL_HOST=auto.nicehash.com
NICEHASH_POOL_PORT=9200

# Mining algorithm passed to T-Rex. The default (ethash) is
# NiceHash DaggerHashimoto and works with auto.nicehash.com:9200.
# Override only if you're targeting a specific NiceHash algorithm port.
NICEHASH_ALGO=ethash

# GPU device index to pass to T-Rex. 0 = first GPU. Useful on
# multi-GPU systems where a specific card handles mining.
MINING_GPU_INDEX=0

# GPU utilisation thresholds for pause/resume (percent). When
# nvidia-smi sees a non-miner CUDA process above PRESSURE_PCT the
# miner is suspended; it resumes when utilisation drops below RESUME_PCT.
# This lets GPU-bound games and AI apps preempt the miner automatically.
MINING_GPU_PRESSURE_PCT=20
MINING_GPU_RESUME_PCT=10

# How often to poll nvidia-smi for GPU pressure, in seconds.
MINING_POLL_INTERVAL_SEC=10

# CSV file path for per-session GPU mining records. Each completed
# session appends one row (start/end/duration/worker/GPU model).
# Useful for CRA income reconciliation against the NiceHash dashboard.
#   Linux:   /var/lib/hadcd-agent/gpu_mining_sessions.csv
#   Windows: C:\ProgramData\hadcd-agent\gpu_mining_sessions.csv
MINING_PAYOUT_LOG=/var/lib/hadcd-agent/gpu_mining_sessions.csv

# =====================================================================
# CPU mining fill — XMRig / P2Pool (Phase 9b)
# =====================================================================
#
# When the backend's fill injector detects idle heat demand, it also
# queues "p2pool_fill" tasks. These run XMRig targeting a P2Pool node
# for Monero CPU mining. Leave XMRIG_PATH empty to disable.
#
# Why P2Pool?
# P2Pool is a decentralised Monero mining pool — no pool operator, no
# KYC, and no PPLNS share-rotation penalty for start/stop cycling.
# Each share pays directly to your wallet as a block-subsidy share.
# This makes it ideal for HADCD's intermittent heat-driven model.
#
# Downloads:
#   XMRig:  https://github.com/xmrig/xmrig/releases
#   P2Pool: https://github.com/SChernykh/p2pool/releases
#           (Optional — P2Pool mini at p2pool.io:3333 is run by the
#            community; you do NOT need to run your own P2Pool node.)

# Full path to the xmrig executable. Leave empty to disable.
#   Linux:   /opt/xmrig/xmrig
#   Windows: C:\XMRig\xmrig.exe
XMRIG_PATH=

# *** Your Monero payout wallet address. Treat as a password. ***
XMR_WALLET_ADDRESS=

# P2Pool stratum URL. Default targets P2Pool mini, which is recommended
# for single GPUs and entry-level mining rigs. The mini chain has a
# lower difficulty and pays more frequently in smaller amounts.
#   P2Pool mini (recommended for RTX-class GPUs): p2pool.io:3333
#   P2Pool main (higher hash rate required):      p2pool.io:3334
P2POOL_NODE_URL=p2pool.io:3333

# Worker label shown in P2Pool's observer UI. Defaults to hostname.
XMRIG_WORKER_NAME=

# CPU threads to use for mining. 0 = auto (all logical cores minus one,
# to leave one core free for the OS and agent). Setting this explicitly
# lets you reserve more headroom on machines that do other real work.
XMRIG_THREADS=0

# How often to check if the task deadline has passed, in seconds.
CPU_MINING_POLL_SEC=15

# CSV file path for per-session CPU mining records.
#   Linux:   /var/lib/hadcd-agent/cpu_mining_sessions.csv
#   Windows: C:\ProgramData\hadcd-agent\cpu_mining_sessions.csv
CPU_MINING_PAYOUT_LOG=/var/lib/hadcd-agent/cpu_mining_sessions.csv

# =====================================================================
# Synthetic heat fill (Phase 9c) — Tier 3 failsafe
# =====================================================================
#
# Pure CPU (optionally GPU) burn used as the last-resort heat source
# when no dispatched work or mining is available but the building still
# demands heat. No wallet, no binary, no external service — always on.

# Burn threads. 0 = auto (all logical cores minus one).
SYNTHETIC_HEAT_THREADS=0

# "true" to also burn the GPU via PyTorch matmul. Requires torch with
# CUDA on the node; silently skipped if unavailable.
SYNTHETIC_HEAT_GPU=false

# How often the burn loop checks its deadline, in seconds.
SYNTHETIC_HEAT_POLL_SEC=1

# CSV file path for per-session synthetic heat records.
SYNTHETIC_HEAT_LOG=/var/lib/hadcd-agent/synthetic_heat_sessions.csv

# =====================================================================
# Geographic location (Phase 11a)
# =====================================================================
#
# WGS-84 decimal coordinates of this node's physical location.
# Required for weather-driven Vast.AI provider windows (Phase 11).
# The agent sends these to the backend at registration; they can also
# be updated later from the operator UI without re-enrolling.
#
# Leave blank if you are not using Vast.AI integration.
NODE_LATITUDE=
NODE_LONGITUDE=
# Human-readable label shown in the operator UI (cosmetic, not parsed).
#   Example: Ottawa, ON, CA
NODE_LOCATION_LABEL=

# =====================================================================
# Vast.AI provider integration (Phase 11c)
# =====================================================================
#
# When VASTAI_API_KEY and VASTAI_MACHINE_ID are both set, the agent
# will automatically list this node on Vast.AI during cold weather
# windows and gracefully unlist when the window ends (or when the node
# is no longer needed as a GPU rental host).
#
# ⚠ SECURITY: VASTAI_API_KEY grants full control of your Vast.AI
#   account (billing, machine management, instance deletion). Store it
#   only in this .env file — never commit it to source control or add
#   it to logs.
#
# Prerequisites:
#   1. Register as a Vast.AI host: https://vast.ai/become-a-host
#   2. Install the CLI: pip install vastai
#   3. Find your machine ID: vastai show machines
#
# Graceful unlist guarantee: the agent will NEVER hard-evict an active
# renter. When a cold window ends, it removes the machine from the
# marketplace (stops new rentals) but waits for any running rental to
# finish naturally before declaring the machine UNLISTED.

# Your Vast.AI API key from https://cloud.vast.ai/account/
VASTAI_API_KEY=

# Your provider machine ID (a number, e.g. 12345)
# Find it with: vastai show machines
VASTAI_MACHINE_ID=

# Path or name of the vastai CLI binary (default: "vastai" on PATH).
# Override with an absolute path if `pip install vastai` put it
# somewhere not on the agent's PATH.
VASTAI_CMD=vastai

# How often the agent checks its Vast.AI schedule (seconds).
# 60 s gives 1-minute reaction time — appropriate for hour-scale windows.
VAST_CHECK_INTERVAL_SEC=60

# How many minutes before a cold window starts to proactively list the
# machine. Gives Vast.AI time to propagate the offer before cold weather
# arrives. Default 10 minutes is a good starting point.
VAST_PRE_LIST_MINUTES=10

# Phase 11d — rental session log.
# Each completed rental cycle is appended to this CSV with columns:
#   listed_at, unlisted_at, duration_hrs, machine_id
#
# Actual USD income must be confirmed from the Vast.AI dashboard —
# the agent tracks time, not money. Leave empty to disable session logging.
#
# Default path works inside the agent container and bare-metal installs
# that use /var/lib/hadcd-agent. On Windows use a local path:
#   VAST_PAYOUT_LOG=C:\ProgramData\hadcd-agent\vast_sessions.csv
VAST_PAYOUT_LOG=/var/lib/hadcd-agent/vast_sessions.csv

# =====================================================================
# Vast.AI autonomous weather thresholds (Phase 15b)
# =====================================================================
#
# When the dispatcher is offline, the agent fetches weather directly from
# Open-Meteo (the same free API the backend uses) and makes its own
# listing/unlisting decisions without waiting to reconnect.
#
# These values should mirror the operator UI settings on the backend
# (Settings → Weather threshold / Minimum window).  If you change the
# backend settings, update these to match.
#
# How the logic works:
#   Cold window (temp < threshold for ≥ min_hours) → UNLIST
#     The GPU is needed for heat workloads; rental income isn't the goal.
#   Outside cold windows → LIST
#     The GPU is free; Vast.AI rental is the highest-value use of it.
#
# Set NODE_LATITUDE + NODE_LONGITUDE (in the Vast.AI section above) for
# this to work.  Without coordinates the agent skips local weather and
# simply holds its last known state until the dispatcher reconnects.

# Temperature band for Vast.AI auto-listing:
#
#   Below VAST_COLD_THRESHOLD_C  → too cold  → unlist, mine locally for heat
#   Between cold and hot thresholds → moderate → list on Vast.AI
#   Above VAST_HOT_THRESHOLD_C   → too hot   → unlist, GPU heat not wanted
#
# Cold threshold: below this the node mines locally instead of listing.
VAST_COLD_THRESHOLD_C=10.0

# Minimum cold-window length (hours) to act on.
VAST_MIN_COLD_HOURS=2.0

# Hot-threshold FLOOR: the effective unlist threshold is
# max(VAST_HOT_THRESHOLD_C, thermostat setpoint). A healthy thermostat's
# setpoint wins; this floor protects against a glitched low setpoint
# keeping the node listed into warm weather. Must match the backend's
# weather_hot_threshold_c for identical offline behaviour.
VAST_HOT_THRESHOLD_C=16.0

# Minimum hot-window length (hours) to act on.
VAST_MIN_HOT_HOURS=2.0

# How often to refresh weather from Open-Meteo while offline (seconds).
VAST_WEATHER_REFRESH_SEC=3600

# =====================================================================
# Autonomous offline fallback (Phase 15a)
# =====================================================================
#
# When the dispatcher has been unreachable for AUTONOMOUS_FALLBACK_AFTER_SEC
# consecutive seconds (roughly 6 missed heartbeats at the default 10-second
# interval), the node enters autonomous mode:
#
#   * GPU mining — runs T-Rex → NiceHash (uses NICEHASH_WALLET above)
#   * CPU mining — runs XMRig → P2Pool (uses XMR_WALLET_ADDRESS above)
#
# Both miners run concurrently while the local thermostat reports heat
# demand (measured_kw > 0). They stop when heat is no longer demanded.
#
# Vast.AI: no action in autonomous mode. If the machine was already listed
# when the dispatcher went offline, that listing persists on Vast.AI's
# side — active rentals continue undisturbed. Listing state changes
# (new listings, graceful unlistings) resume when the dispatcher reconnects.
#
# Session logs: autonomous sessions are written to the same CSV files as
# dispatcher-assigned sessions (MINING_PAYOUT_LOG / CPU_MINING_PAYOUT_LOG).
#
# Set AUTONOMOUS_FALLBACK_AFTER_SEC=0 to disable autonomous mode entirely.

# Seconds of consecutive heartbeat failures before entering autonomous mode.
AUTONOMOUS_FALLBACK_AFTER_SEC=60

# Duration of each mining chunk while in autonomous mode (seconds).
# After each chunk the thermostat is re-checked; if heat is no longer
# demanded the miners stop.
AUTONOMOUS_CHUNK_SEC=120

# =====================================================================
# Blob storage for container task I/O (Phase 10c)
# =====================================================================

# Where the agent stages downloaded input blobs before mounting them
# into container tasks, and reads output blobs before uploading them.
# Must be on a filesystem the Docker daemon can bind-mount from.
#   Linux:   /var/lib/hadcd-agent/blobs
#   Windows: C:\ProgramData\hadcd-agent\blobs
BLOB_STORAGE_DIR=/var/lib/hadcd-agent/blobs

# =====================================================================
# Container task security floor
# =====================================================================
#
# These two settings are deliberately LOCAL — the dispatcher can never
# widen them through a task payload. See docs/THREAT-MODEL.md.

# Extra host-path prefixes that dispatched container tasks may
# bind-mount, separated by ':' on Linux (';' on Windows). The agent's
# own blob-staging temp dirs are always mountable; every other
# payload-supplied host path is rejected unless it sits under one of
# these prefixes. Leave empty (the safe default) unless this node runs
# trusted operator tasks that mount host data directories.
#   Example: /var/lib/hadcd-agent/blobs:/mnt/datasets
CONTAINER_MOUNT_ALLOWLIST=

# "true" to run EVERY container task on this node with the full
# hardened floor (cap_drop=ALL, no-new-privileges, unprivileged,
# isolated bridge network), even tasks the dispatcher marked as
# trusted operator work. Recommended for independent/BYO hosts that
# do not operate their own dispatcher.
CONTAINER_REQUIRE_HARDENED=false

# =====================================================================
# Kasa smart-plug power meter (Phase 16b)
# =====================================================================
#
# Real measured wattage for earnings records: plug the node's power
# supply into a TP-Link Kasa plug and the agent replaces estimated
# power with measured power in task results. Leave KASA_PLUG_IP empty
# to disable (the agent then uses the task's estimated power).

# LAN IP of the Kasa plug, e.g. 192.168.1.60.
KASA_PLUG_IP=

# TP-Link account credentials — required for KP125M (KLAP protocol).
# Older plugs (KP115, non-M KP125) work with these left empty.
KASA_USERNAME=
KASA_PASSWORD=

# How often to poll the plug, in seconds.
KASA_POLL_INTERVAL_SEC=10

# =====================================================================
# Node role (Phase 18j)
# =====================================================================
#
#   standard  — thermostat-controlled heater node. Sessions are assigned
#               when the heat source reports demand; Vast.AI listing
#               follows the weather schedule.
#   always_on — dedicated always-on server: no thermostat, no Vast.AI.
#               Receives sessions as fallback when no standard node is
#               demanding heat.
NODE_ROLE=standard

# =====================================================================
# Shared asset storage (Phase 20a/20c)
# =====================================================================

# Absolute path to the directory this node contributes as shared
# storage for the HADCD asset library (LoRAs, documents, datasets).
# Leave empty (default) to opt out of storage contribution.
#   Examples: /mnt/data    /var/lib/hadcd-assets
STORAGE_PATH=

# Port for this node's P2P storage server. The server binds the node's
# Tailscale IP (loopback if Tailscale is down — never all interfaces);
# peers fetch content-addressed files at
#   http://{tailscale_ip}:{port}/pool/{sha256}
# Change only if 8015 conflicts with another service.
STORAGE_SERVER_PORT=8015
